VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Error tracking (opcional). Si lo dejas vacío, no se carga Sentry: solo
# quedan los handlers globales locales. Pega aquí el DSN de tu proyecto Sentry
# para activar el reporte de errores en producción.
VITE_SENTRY_DSN=

# Hosts (CSV) desde los que SÍ se envían errores a Sentry. Por defecto solo el
# dominio oficial; así un fork desplegado en otro github.io no manda errores a
# tu proyecto. Cámbialo si usas un dominio propio. Ej: midominio.com,www.midominio.com
VITE_SENTRY_ALLOWED_HOSTS=
