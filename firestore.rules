rules_version = '2';

// Reglas: cada usuario solo puede leer/escribir su propio documento
// users/{uid}. Nadie puede listar la colección entera ni leer la de otro.
// Además validamos esquema y tamaños para evitar que una cuenta escriba
// campos arbitrarios o documentos gigantes (abuso de almacenamiento/cuota).
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Valida la forma del documento que se intenta escribir. Solo permitimos
    // las claves que la app realmente usa (userStore.js) y acotamos tipos y
    // tamaños. `progress` y `extra` son mapas libres (subsistemas internos),
    // pero el límite de 1 MB por documento de Firestore sigue aplicando.
    function isValidUser() {
      let d = request.resource.data;
      return d.keys().hasOnly(
               ['userName', 'profile', 'progress', 'extra', 'clientId', 'updatedAt'])
        && (!d.keys().hasAny(['userName']) || (d.userName is string && d.userName.size() <= 100))
        && (!d.keys().hasAny(['profile'])  || d.profile is map)
        && (!d.keys().hasAny(['progress']) || d.progress is map)
        && (!d.keys().hasAny(['extra'])    || d.extra is map)
        && (!d.keys().hasAny(['clientId']) || (d.clientId is string && d.clientId.size() <= 100));
    }

    match /users/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid) && isValidUser();
    }

    // Todo lo demás queda denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
