rules_version = '2';

// Reglas: cada usuario solo puede leer/escribir su propio documento
// users/{uid}. Nadie puede listar la colección entera ni leer la de otro.
// Además validamos esquema y tamaños para evitar que una cuenta escriba
// campos arbitrarios o documentos gigantes (abuso de almacenamiento/cuota).
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Valida la forma del documento que se intenta escribir. Solo permitimos
    // las claves que la app realmente usa (userStore.js) y acotamos tipos y
    // tamaños. `progress` y `extra` son mapas libres (subsistemas internos),
    // pero el límite de 1 MB por documento de Firestore sigue aplicando.
    function isValidUser() {
      let d = request.resource.data;
      return d.keys().hasOnly(
               ['userName', 'profile', 'progress', 'extra', 'clientId', 'updatedAt'])
        && (!d.keys().hasAny(['userName']) || (d.userName is string && d.userName.size() <= 100))
        && (!d.keys().hasAny(['profile'])  || d.profile is map)
        && (!d.keys().hasAny(['progress']) || d.progress is map)
        && (!d.keys().hasAny(['extra'])    || d.extra is map)
        && (!d.keys().hasAny(['clientId']) || (d.clientId is string && d.clientId.size() <= 100));
    }

    match /users/{uid} {
      allow read:  if isOwner(uid);
      // create/update validan esquema; delete va aparte (en un delete no hay
      // request.resource.data y isValidUser() lo bloquearía). Necesario para
      // el borrado de cuenta desde Ajustes.
      allow create, update: if isOwner(uid) && isValidUser();
      allow delete: if isOwner(uid);
    }

    // ─── Capa social (amistades) ──────────────────────────────────────────
    // Perfil PÚBLICO: solo los campos mínimos que se comparten con amigos
    // (nombre, avatar, nivel, XP, racha, código). Lo lee cualquier usuario
    // autenticado (hace falta para el ranking y para resolver invitaciones);
    // solo el dueño lo escribe. El doc privado users/{uid} NO se toca aquí.
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow create, update: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['uid', 'displayName', 'avatarId', 'photoURL',
              'level', 'totalXP', 'weeklyXP', 'currentStreak', 'friendCode', 'updatedAt'])
        && request.resource.data.uid == uid
        && (request.resource.data.displayName is string
            && request.resource.data.displayName.size() <= 100);
      // Borrado de cuenta desde Ajustes.
      allow delete: if isOwner(uid);
    }

    // Lookup código→uid. create() falla si el código ya existe, lo que
    // garantiza unicidad sin transacciones. Solo el dueño reserva/borra.
    match /friendCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Invitaciones pendientes. Id determinista "{from}_{to}" → evita duplicados.
    // Solo emisor y receptor pueden verla; solo el emisor la crea; ambos la
    // borran (rechazar / cancelar). No hay update: aceptar = crear amistad +
    // borrar invitación (ver friendships).
    match /friendRequests/{reqId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid
        && request.resource.data.from != request.resource.data.to
        && reqId == request.resource.data.from + '_' + request.resource.data.to
        && request.resource.data.keys().hasOnly(
             ['from', 'to', 'fromName', 'fromAvatarId', 'fromPhotoURL',
              'toName', 'toAvatarId', 'toPhotoURL', 'createdAt'])
        && request.resource.data.fromName is string
        && request.resource.data.fromName.size() <= 100
        && (!request.resource.data.keys().hasAny(['toName'])
            || (request.resource.data.toName is string
                && request.resource.data.toName.size() <= 100));
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    // Amistad confirmada. members = los dos uid. Solo un miembro la lee/borra.
    // Crear solo si soy uno de los miembros Y el OTRO me había enviado una
    // invitación pendiente (así nadie se autoañade a la lista de otro).
    match /friendships/{pairId} {
      function otherMember(members) {
        return members[0] == request.auth.uid ? members[1] : members[0];
      }
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members
        && exists(/databases/$(database)/documents/friendRequests/$(
             otherMember(request.resource.data.members) + '_' + request.auth.uid));
    }

    // Todo lo demás queda denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
